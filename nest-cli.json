{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [{
      "include": "*.env*",
      "outDir": "dist"
    }, {
      "include": "../public/**/*",
      "outDir": "dist/public"
    }]
  }
}